# Theme & Style
background_opacity 0.98
tab_bar_style powerline
window_padding_width 10
remember_window_size no
initial_window_width 90c
initial_window_height 40c

# Font
font_family RobotoMono Nerd Font Mono
font_size 11
disable_ligatures always
font_features none

# Cursor
cursor_shape underline
shell_integration no-cursor

# Mouse
mouse_hide_wait 3.0

# URLs
detect_urls yes
url_style curly

# KEYBINDINGS
# Move the active window in the indicated direction
map shift+up move_window up 
map shift+left move_window left
map shift+right move_window right
map shift+down move_window down

# Switch focus to the neighboring window in the indicated direction
map ctrl+alt+left neighboring_window left
map ctrl+alt+right neighboring_window right
map ctrl+alt+up neighboring_window up
map ctrl+alt+down neighboring_window down

# Resize Windows
map ctrl+shift+right resize_window narrower 3
map ctrl+shift+left resize_window wider 3
map ctrl+shift+up resize_window taller 3
map ctrl+shift+down resize_window shorter 3
# reset all windows in the tab to default sizes
map ctrl+home resize_window reset

# Layout
map ctrl+shift+z toggle_layout horizontal

# Tabs
map ctrl+shift+enter new_window_with_cwd
map ctrl+shift+t new_tab_with_cwd

shell zsh



# BEGIN_KITTY_THEME
# Nord
include current-theme.conf
# END_KITTY_THEME
