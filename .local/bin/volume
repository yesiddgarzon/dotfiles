#!/bin/bash

# variables
ICONS="$HOME/.config/dunst/icons"
# SINK="`pactl list sinks short | grep RUNNING | sed 's/\s[a-z,A-Z,0-9].*//'`"

get_volume () {
  pactl get-sink-volume @DEFAULT_SINK@ | grep -o '[0-9]\{1,3\}%' | sed 's/%//' | head -1
}

is_muted () {
  pactl list sinks | grep Mute | grep "yes"
}

notify () {
  volume=`get_volume`

  if [ "$volume" = "0" ]; then
    icon="$ICONS/volume-muted.svg"
  else
    if [  "$volume" -lt "10" ]; then
      icon="$ICONS/volume-low.svg"
    else
      if [ "$volume" -lt "30" ]; then
        icon="$ICONS/volume-low.svg"
      else
        if [ "$volume" -lt "70" ]; then
          icon="$ICONS/volume-medium.svg"
        else
          icon="$ICONS/volume-high.svg"
        fi
      fi
    fi
  fi 

  dunstify -i "$icon" -t 2000 -r 123 "Volume" "On $volume%"
}

case $1 in
  up)
    pactl set-sink-volume @DEFAULT_SINK@ false > /dev/null
    pactl set-sink-volume @DEFAULT_SINK@ +2%
    notify
    ;;
  down)
    pactl set-sink-volume @DEFAULT_SINK@ false > /dev/null
    pactl set-sink-volume @DEFAULT_SINK@ -2%
    notify
    ;;
  mute)
    pactl set-sink-volume @DEFAULT_SINK@ toggle > /dev/null
    if is_muted ; then
      icon="$DIR/volume-muted.svg"
      dunstify -i $icon -r 5555 -u normal -h int:value:0
    else
      notify
    fi
    ;;
esac
